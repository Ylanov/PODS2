{
    "manifest_version": 3,
    "name": "pods2 — мост СЭД",
    "version": "0.3.0",
    "description": "Раз в 5 минут читает разделы СЭД в фоне (под уже залогиненной сессией пользователя) и шлёт в pods2: дайджест + ТЕЛА писем (содержание+метаданные+ссылки на файлы). Без передачи паролей. Никаких workflow-действий (делегирование/подпись) от имени пользователя.",

    "permissions": [
        "alarms",
        "storage",
        "notifications",
        "downloads"
    ],
    "host_permissions": [
        "https://sed.mchs.ru/*",
        "https://staff.asy-tk.ru/*"
    ],

    "background": {
        "service_worker": "background.js",
        "type": "module"
    },

    "content_scripts": [
        {
            "matches": [
                "https://staff.asy-tk.ru/*",
                "https://staff.app/*",
                "http://localhost/*",
                "http://127.0.0.1/*"
            ],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],

    "action": {
        "default_title": "СЭД-мост pods2",
        "default_popup": "popup.html",
        "default_icon": {
            "16":  "icons/16.png",
            "48":  "icons/48.png",
            "128": "icons/128.png"
        }
    },

    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },

    "icons": {
        "16":  "icons/16.png",
        "48":  "icons/48.png",
        "128": "icons/128.png"
    }
}
